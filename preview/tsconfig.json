{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2018",
        "jsx": "react-jsx",
        //"jsxFactory": "h",
        "jsxImportSource": "preact",
        "allowJs": true,
        "checkJs": false,
        "rootDir": "../", 
        "outDir": "./js/",
        "sourceMap": true,
        "strict": true,
        "noUnusedLocals": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*",
        "dist",
        "out",
        "../node_modules",
    ],
    "include": [
        "src/**/*"
    ]
}